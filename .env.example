# ============================================================
#  Company Domain Classifier – Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git — it contains your API keys!
# ============================================================


# ── API Keys (Required) ──────────────────────────────────────
# Get free keys at: https://aistudio.google.com/app/apikey
#
# Single key:
# GEMINI_API_KEYS=AIzaSyYOUR_KEY_HERE
#
# Multiple keys — recommended! Rotates round-robin; on 429 switches instantly.
# Each key must come from a different Google account (separate quota).
GEMINI_API_KEYS=AIzaSyKEY1,AIzaSyKEY2,AIzaSyKEY3


# ── Model ────────────────────────────────────────────────────
# Recommended free-tier model:
MODEL_NAME=gemini-2.5-flash-lite

# Other options (check availability in your region):
# MODEL_NAME=gemini-2.0-flash
# MODEL_NAME=gemini-1.5-flash


# ── File Paths ───────────────────────────────────────────────
# Use absolute paths to avoid confusion.
INPUT_EXCEL=/full/path/to/your/companies_input.xlsx
OUTPUT_EXCEL=classified_companies.xlsx


# ── Batch Processing ─────────────────────────────────────────
# Companies sent per API call. Higher = fewer calls needed.
# 20 is the sweet spot (balances token limits vs. efficiency).
BATCH_SIZE=20

# Number of batches running in parallel.
# Keep at 3 unless you have many API keys.
MAX_WORKERS=3


# ── Rate Limiting ────────────────────────────────────────────
# Requests per minute PER KEY (Gemini free tier = ~20 RPM).
# With multiple keys, effective RPM = REQUESTS_PER_MINUTE × number_of_keys.
REQUESTS_PER_MINUTE=8


# ── Reliability ──────────────────────────────────────────────
# How many times to retry a failed batch before giving up.
MAX_RETRIES=5

# Base delay (seconds) between retries. Multiplied by attempt number.
RETRY_DELAY=5.0

# Save progress to *_partial.xlsx every N batches.
# Each batch = BATCH_SIZE companies. So 5 batches = 100 companies saved.
PARTIAL_SAVE_EVERY=5


# ── Network ──────────────────────────────────────────────────
# Seconds to wait for an API response before timing out.
REQUEST_TIMEOUT=30


# ── Logging ──────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
