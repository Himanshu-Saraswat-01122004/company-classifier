# ─────────────────────────────────────────────────────────────────────────────
# .env.example – Copy this to .env and fill in your values.
# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: Your Gemini API key ────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy-your-gemini-api-key

# ── Optional: Override model (defaults to gemini-2.0-flash) ──────────────────
# MODEL_NAME=gemini-2.0-flash          # Fast, cheap (recommended default)
# MODEL_NAME=gemini-2.0-flash-lite     # Even cheaper / faster
# MODEL_NAME=gemini-1.5-pro            # Higher accuracy
# MODEL_NAME=gemini-1.5-flash          # Good balance

# ── Optional: Override the API endpoint (rarely needed) ───────────────────────
# API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent

# ── Optional: File paths ──────────────────────────────────────────────────────
# INPUT_EXCEL=companies_input.xlsx
# OUTPUT_EXCEL=classified_companies.xlsx

# ── Optional: Performance tuning ─────────────────────────────────────────────
# MAX_WORKERS=10          # Concurrent API calls (Gemini free tier: 15 RPM)
# REQUEST_TIMEOUT=30      # Seconds per API call before timeout
# MAX_RETRIES=3           # Retry failed API calls
# RETRY_DELAY=2.0         # Base delay between retries (seconds × attempt)
# PARTIAL_SAVE_EVERY=20   # Save partial results every N completions

# ── Optional: Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
